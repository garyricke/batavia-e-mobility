# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Claude Code local state
.claude/

# Secrets / env
.env
.env.*
*.pem

# Cloudinary upload manifest (internal, not for repo)
.cloudinary-uploads.json

# Node / build artifacts (in case the project ever grows tooling)
node_modules/
dist/
build/
*.log

# Rendered video artifacts — large binaries, hosted on Cloudinary instead.
# PRODUCTION.md files document exactly how to regenerate from keyframes.
campaign/videos/*.mp4
campaign/videos/*.mov
campaign/videos/*.webm

# Unencrypted source for password-protected pages — must NEVER be committed
# to the public repo, or the password protection is meaningless.
# Edit the .source.html file, then run `python3 encrypt-page.py` to publish.
*.source.html
