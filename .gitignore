# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Claude Code local state (keep shared skills, ignore machine-specific settings)
.claude/*
!.claude/skills/

# Secrets / env
.env
.env.*
*.pem

# Cloudinary upload manifests (internal, not for repo)
.cloudinary-uploads.json
.cloudinary-videos.json

# Node / build artifacts (in case the project ever grows tooling)
node_modules/
dist/
build/
*.log

# Rendered video artifacts — large binaries, hosted on Cloudinary instead.
# PRODUCTION.md files document exactly how to regenerate from keyframes.
campaign/videos/*.mp4
campaign/videos/*.mov
campaign/videos/*.webm

# Final squad source videos — uploaded to Cloudinary, never committed.
assets/0-final-videos/

# Raw source clips & audio dropped into assets/ (hosted on Cloudinary, not committed)
assets/*.mp4
assets/*.mov
assets/*.mp3
assets/*.m4a
assets/*.wav

# Nano-banana scratch outputs — keep only canonical pixar-*/end-card-* files
generated_imgs/edited-*.png

# Local pre-edit page backups (git history is the real backup)
index-backup-*.html

# Unencrypted source for password-protected pages — must NEVER be committed
# to the public repo, or the password protection is meaningless.
# Edit the .source.html file, then run `python3 encrypt-page.py` to publish.
*.source.html
